# ─── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ─── Authentication (JWT) ─────────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d

# ─── Client ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
CLIENT_URL=http://localhost:5173

# ─── Simulation / Game Balance ────────────────────────────────────
BANKRUPTCY_THRESHOLD_WEEKS=4
MAX_ACTIVE_LOANS=3

# ─── Performance ──────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000

# ─── Logging ──────────────────────────────────────────────────────
# Morgan format: dev (concise) | combined (verbose) | tiny | short
LOG_LEVEL=dev
